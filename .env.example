# Database Configuration
POSTGRES_DB=emotivapoli
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin123

# pgAdmin Configuration
PGADMIN_DEFAULT_EMAIL=admin@emotivapoli.com
PGADMIN_DEFAULT_PASSWORD=admin123

# FastAPI Configuration
FASTAPI_SECRET_KEY=your-secret-key-change-in-production
FASTAPI_ALGORITHM=HS256
FASTAPI_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Spring Boot Configuration
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/emotivapoli
SPRING_DATASOURCE_USERNAME=admin
SPRING_DATASOURCE_PASSWORD=admin123

# Ports
POSTGRES_PORT=5432
PGADMIN_PORT=5050
FASTAPI_PORT=5000
SPRINGBOOT_PORT=6000
REACT_PORT=3000

# IA Gateway Next
IA_GATEWAY_PORT=3001
VITE_IA_GATEWAY_URL=http://localhost:3001
GROQ_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
CEREBRAS_API_KEY=
MISTRAL_API_KEY=
COHERE_API_KEY=
